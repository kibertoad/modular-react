# link-workspace-packages: always symlink sibling workspace packages instead
# of fetching them from the registry, even when a dep is declared with a
# concrete version (not workspace:*). Keeps local dev pointed at the local
# source.
link-workspace-packages=true
# prefer-workspace-packages: if a dep range is satisfied by both a workspace
# package and a registry version, pick the workspace one. Without this, pnpm
# can resolve to a published version that happens to match the declared
# range, silently bypassing local changes.
prefer-workspace-packages=true
manage-package-manager-versions=false
