{
  "name": "@modular-react/core",
  "version": "2.7.0",
  "description": "React binding facade over @modular-frontend/core. Re-exports the framework-neutral primitives (types, slots, navigation, validation, journey contracts, store) for modular React applications.",
  "repository": {
    "type": "git",
    "url": "git://github.com/kibertoad/modular-react.git",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@modular-frontend/core": "workspace:*",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "rolldown-plugin-dts": "^0.26.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "@modular-frontend/core": ">=0.1.0 <2.0.0"
  }
}
