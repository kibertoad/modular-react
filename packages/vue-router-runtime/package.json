{
  "name": "@modular-vue/runtime",
  "version": "0.1.0",
  "description": "vue-router runtime for @modular-vue modules: createRegistry with module registration, dependency validation, lifecycle hooks, plugin machinery, and manifest resolution.",
  "repository": {
    "type": "git",
    "url": "git://github.com/kibertoad/modular-react.git",
    "directory": "packages/vue-router-runtime"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@modular-frontend/core": "workspace:*",
    "@modular-frontend/journeys-engine": "workspace:*",
    "@modular-vue/core": "workspace:*",
    "@modular-vue/journeys": "workspace:*",
    "@modular-vue/vue": "workspace:*",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.9.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "rolldown-plugin-dts": "^0.26.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "peerDependencies": {
    "@modular-frontend/core": "^0.1.0",
    "@modular-vue/core": "^0.1.0",
    "@modular-vue/vue": "^0.1.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  }
}
