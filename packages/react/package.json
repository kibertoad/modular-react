{
  "name": "@modular-react/react",
  "version": "1.3.0",
  "description": "React bindings for @modular-react/core: hooks, contexts, error boundaries, and scoped stores.",
  "repository": {
    "type": "git",
    "url": "git://github.com/kibertoad/modular-react.git",
    "directory": "packages/react"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@modular-react/core": "^1.2.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.9.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@modular-react/core": "^1.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
