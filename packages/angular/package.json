{
  "name": "@modular-angular/angular",
  "version": "0.1.0",
  "description": "Angular bindings for @modular-frontend/core: store/reactive-service signal bridges, scoped stores, and injection-token contexts for modules, navigation, and slots.",
  "repository": {
    "type": "git",
    "url": "git://github.com/kibertoad/modular-react.git",
    "directory": "packages/angular"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@modular-frontend/core": "workspace:*",
    "happy-dom": "^20.9.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "rolldown-plugin-dts": "^0.26.0",
    "rxjs": "^7.8.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "@angular/core": "^20.0.0 || ^21.0.0 || ^22.0.0",
    "@modular-frontend/core": ">=0.1.0 <2.0.0"
  }
}
