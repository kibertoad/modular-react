  "journeys/customer-onboarding/src/customer-onboarding.ts": "import { defineJourney, defineJourneyHandle } from '@modular-vue/journeys'
import type dashboardModule from '@acme/dashboard-module'
import type ordersModule from '@acme/orders-module'

// All module imports are \`import type\` — the runtime resolves entries by id
// against the registered descriptors, so this package stays bundle-free of
// module code.
type CustomerOnboardingModules = {
  readonly dashboard: typeof dashboardModule;
  readonly orders: typeof ordersModule;
}

export interface CustomerOnboardingInput {
  // TODO: shape the input the caller passes to runtime.start(handle, input).
  readonly customerId: string;
}

export interface CustomerOnboardingState {
  // TODO: shape the state shared across steps. Keep it serializable —
  // persistence adapters round-trip it via JSON.
  readonly customerId: string;
}

export const customerOnboardingJourney = defineJourney<CustomerOnboardingModules, CustomerOnboardingState>()({
  id: 'customer-onboarding',
  version: '1.0.0',
  meta: {
    name: 'CustomerOnboarding',
  },

  initialState: ({ customerId }: CustomerOnboardingInput) => ({
    customerId,
  }),

  start: (state) => ({
    module: 'dashboard',
    // TODO: pick an entry name your dashboard module exposes via entryPoints.
    entry: 'TODO_entry_name' as const,
    input: state,
  }),

  transitions: {
    dashboard: {
      // TODO: list each entry name you handle and one branch per exit it can emit.
      // Example shape:
      //   <entry>: {
      //     <exitName>: ({ output, state }) => ({ complete: { ... } }),
      //     cancelled: () => ({ abort: { reason: 'cancelled' } }),
      //   }
    },
  },
})

/**
 * Typed token for opening this journey. Modules and shells import this
 * (via \`import type\`) to call \`runtime.start(handle, input)\` with full
 * input checking — without pulling the journey's runtime into the caller.
 */
export const customerOnboardingHandle = defineJourneyHandle(customerOnboardingJourney)
export type CustomerOnboardingHandle = typeof customerOnboardingHandle
