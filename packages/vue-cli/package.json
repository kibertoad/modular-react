{
  "name": "@modular-vue/cli",
  "version": "1.2.0",
  "repository": {
    "type": "git",
    "url": "git://github.com/kibertoad/modular-react.git",
    "directory": "packages/vue-cli"
  },
  "bin": {
    "modular-vue": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "clean": "rimraf dist .test-output",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modular-react/cli-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "cli-testlab": "^6.0.1",
    "rimraf": "^6.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
