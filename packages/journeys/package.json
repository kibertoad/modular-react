{
  "name": "@modular-react/journeys",
  "version": "0.1.0",
  "description": "Typed, serializable workflows that compose multiple modules. A journey declares entry/exit transitions between modules and owns shared state; modules stay journey-unaware.",
  "repository": {
    "type": "git",
    "url": "git://github.com/kibertoad/modular-react.git",
    "directory": "packages/journeys"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "bench": "vitest bench --run bench",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@modular-react/core": "workspace:*",
    "@modular-react/react": "workspace:*",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "happy-dom": "^20.9.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "react": "^19.2.5",
    "react-dom": "^19.0.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@modular-react/core": "^1.2.0",
    "@modular-react/react": "^1.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
